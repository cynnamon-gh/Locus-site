# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Verified sender in Resend (e.g. onboarding@resend.dev for testing, or your domain)
RESEND_FROM_EMAIL=Locus <onboarding@resend.dev>

# Inbox that receives contact form submissions
CONTACT_EMAIL=you@example.com

# Public site URL for Open Graph (set to your Railway domain after deploy)
NEXT_PUBLIC_SITE_URL=https://your-app.up.railway.app
